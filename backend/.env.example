# Copy to .env and fill in values. Never commit .env with real secrets.

OPENALEX_USER_AGENT=https://github.com/eashanroy7/aethena
EVIDENCE_DB_PATH=./evidence.db
PAPER_FETCH_DELAY_SECONDS=0.2
OPENALEX_PER_PAGE_MULTIPLIER=5
OPENALEX_TIMEOUT_SECONDS=30
PMC_TIMEOUT_SECONDS=30
MAX_PAPERS_DEFAULT=10

# Agent 1: OpenAI query expansion before OpenAlex (optional but recommended)
OPENAI_API_KEY=
# Examples: o3-mini, o1-mini, o1, gpt-4o
OPENAI_AGENT1_MODEL=o3-mini

PORT=8000
